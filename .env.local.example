# AI Gateway
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
AI_GATEWAY_URL=https://ai-gateway.vercel.sh/v1

# Vercel REST API (for programmatic deployments)
VERCEL_TOKEN=
VERCEL_TEAM_ID=

# Credential security — shared across all deployed MCP servers
# CREDENTIAL_HMAC_SECRET: used by /api/credentials to verify requests from deployed servers
# NEXT_PUBLIC_APP_URL is also injected into deployed servers as CREDENTIAL_ENDPOINT
CREDENTIAL_HMAC_SECRET=

# Storage (Vercel Marketplace)
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
DATABASE_URL=

# Credential encryption
ENCRYPTION_KEY=

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000
